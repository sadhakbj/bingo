#!/usr/bin/env php
<?php

/*
|--------------------------------------------------------------------------
| Register The Auto Loader
|--------------------------------------------------------------------------
|
| Composer provides a convenient, automatically generated class loader for
| our application. We just need to utilize it! We'll simply require it
| into the script here so that we don't have to worry about manual loading.
|
*/

$app = require_once __DIR__ . '/../bootstrap/app.php';

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Console\Helper\Table;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Output\OutputInterface;

class ShowRoutesCommand extends Command
{
    private $app;
    
    public function __construct($app)
    {
        parent::__construct();
        $this->app = $app;
    }

    protected function configure(): void
    {
        $this
            ->setName('show:routes')
            ->setDescription('Display all registered routes');
    }

    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $router = $this->app->getRouter();
        $routes = $router->getRoutes();

        $table = new Table($output);
        $table->setHeaders(['Method', 'Path', 'Controller', 'Action', 'Middleware']);

        foreach ($routes as $name => $route) {
            $defaults = $route->getDefaults();
            $controller = $defaults['_controller'] ?? '';
            $action = $defaults['_action'] ?? '';
            $middlewares = $router->getMiddlewaresForRoute($name);
            $table->addRow([
                implode(',', $route->getMethods()),
                $route->getPath(),
                $controller,
                $action,
                implode(', ', $middlewares)
            ]);
        }

        $table->render();
        return Command::SUCCESS;
    }
}

$console = new Application('AttrFlow Framework', '1.0.0');
$console->addCommand(new ShowRoutesCommand($app));
$console->run();
