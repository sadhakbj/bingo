# Application
APP_NAME=Bingo
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# ──────────────────────────────────────────────
# Database — choose a driver and fill in the
# matching block below. Other blocks are ignored.
# ──────────────────────────────────────────────
DB_CONNECTION=sqlite   # sqlite | mysql | pgsql

# SQLite (default — zero setup)
DB_DATABASE=database/database.sqlite

# MySQL / MariaDB
#DB_CONNECTION=mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_DATABASE=bingo
#DB_USERNAME=root
#DB_PASSWORD=secret
#DB_CHARSET=utf8mb4
#DB_COLLATION=utf8mb4_unicode_ci

# PostgreSQL
#DB_CONNECTION=pgsql
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_DATABASE=bingo
#DB_USERNAME=postgres
#DB_PASSWORD=secret
#DB_CHARSET=utf8

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0

# Rate Limiting (active in production only)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# ──────────────────────────────────────────────
# Logging
# LOG_FORMAT: text (slog-style key=value, default) | json
# LOG_STDERR_LEVEL: minimum level written to stderr (ERROR+ by default)
#                  set to debug or info to see your own log calls in the terminal
# ──────────────────────────────────────────────
LOG_FORMAT=text
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_STDERR_LEVEL=error
LOG_PATH=storage/logs/bingo.log
