{
    "name": "sadhakbj/bingo",
    "description": "Bingo - A PHP 8.3+ API-first microservice framework with attribute-based routing",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Core\\": "core/",
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Bijaya Prasad Kuikel",
            "email": "sadhakbj@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/database": "^13.2.0",
        "symfony/http-foundation": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/console": "^8.0",
        "symfony/validator": "^8.0",
        "vlucas/phpdotenv": "^5.5"
    },
    "require-dev": {
        "symfony/var-dumper": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    }
}
