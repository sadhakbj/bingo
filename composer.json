{
    "name": "sadhakbj/bingo",
    "description": "Bingo - A PHP 8.4+ API-first microservice framework with attribute-based routing",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bingo\\": "core/Bingo/",
            "App\\": "app/",
            "Config\\": "config/"
        },
        "files": [
            "core/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Bijaya Prasad Kuikel",
            "email": "sadhakbj@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "illuminate/database": "^13.2.0",
        "symfony/http-foundation": "^8.0",
        "symfony/routing": "^8.0",
        "symfony/console": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "vlucas/phpdotenv": "^5.5",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "symfony/var-dumper": "^8.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "ext-redis": "Required for Redis rate limiting in production (recommended). Install via pecl install redis.",
        "predis/predis": "Pure-PHP Redis client — alternative to ext-redis when installing a PHP extension is not an option."
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    }
}
